# WikiMind Environment Configuration
# Copy this file to .env and fill in your actual values.
# All variables below are read by backend/config.py via Pydantic BaseSettings.

# ---------------------------------------------------------------------------
# OpenAI (Embeddings and Generation)
# ---------------------------------------------------------------------------
OPENAI_API_KEY="sk-placeholder"
OPENAI_MODEL="gpt-4o-mini"

# ---------------------------------------------------------------------------
# Embedding Model
# ---------------------------------------------------------------------------
# Options:
#   "BAAI/bge-small-en-v1.5" (384 dims, free, local via FastEmbed)
#   "BAAI/bge-base-en-v1.5"  (768 dims, free, local via FastEmbed)
#   "text-embedding-3-small" (1536 dims, paid, OpenAI API)
EMBEDDING_MODEL="BAAI/bge-small-en-v1.5"
EMBEDDING_DIM=384

# ---------------------------------------------------------------------------
# Qdrant Vector Database
# ---------------------------------------------------------------------------
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_COLLECTION="wikimind_hybrid"

# ---------------------------------------------------------------------------
# Redis Stack (Semantic Cache)
# ---------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"
CACHE_SIMILARITY_THRESHOLD=0.92
CACHE_TTL_STATIC=86400
CACHE_TTL_DYNAMIC=3600

# ---------------------------------------------------------------------------
# Langfuse Observability
# ---------------------------------------------------------------------------
LANGFUSE_SECRET_KEY="sk-lf-placeholder"
LANGFUSE_PUBLIC_KEY="pk-lf-placeholder"
LANGFUSE_HOST="https://cloud.langfuse.com"

# ---------------------------------------------------------------------------
# Tavily Web Search (CRAG Fallback)
# ---------------------------------------------------------------------------
TAVILY_API_KEY="tvly-placeholder"

# ---------------------------------------------------------------------------
# Retrieval Parameters
# ---------------------------------------------------------------------------
RETRIEVAL_TOP_K=50
RRF_K=60
RERANKER_TOP_K=5
RERANKER_MODEL="ms-marco-MiniLM-L-12-v2"

# ---------------------------------------------------------------------------
# Application Server
# ---------------------------------------------------------------------------
APP_HOST="0.0.0.0"
APP_PORT=8000
LOG_LEVEL="INFO"

# ---------------------------------------------------------------------------
# Wikipedia Sync
# ---------------------------------------------------------------------------
WIKI_STREAM_URL="https://stream.wikimedia.org/v2/stream/recentchange"
WIKI_RECONCILE_INTERVAL_HOURS=24
